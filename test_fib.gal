// Function to calculate Fibonacci numbers
pollinate seed fibonacci(seed n) {
    // Base cases for Fibonacci sequence
    spring (n <= 1) {
        reclaim n;
    }
    // Recursive step: fib(n) = fib(n-1) + fib(n-2)
    reclaim fibonacci(n - 1) + fibonacci(n - 2);
}

root() {
    seed numTerms = 10; // Number of Fibonacci terms to generate

    plant("Generating Fibonacci sequence up to {} terms:", numTerms);

    // Loop to print each Fibonacci number
    cultivate(seed i = 0; i < numTerms; i++) {
        plant(fibonacci(i));
    }

    reclaim;
}
