root() {
    tree z = 2.03;
    branch m;
    branch prev = frost;
    seed x = 66;
    tree idx[2][3];
    tree cnt[5];
    
    spring (22 > ((44 + x) * 29) && (z - x) <= z) {
        z -= 15.46;
        x = (seed)z;
    } bud (71 >= z && ((z + z) - x) == 92) {
        idx[0][0] = 26.44;
    }
    plant("{}", z);
    plant("{}", prev);
    plant("test output");
    compute(35, x, 71);
    
    reclaim;
