    plant("fn called");
    reclaim;
}

root() {
    branch d = sunshine;
    tree omega = 57.76;
    seed res = 31;
    seed y;
    tree num[6][3];
    
    harvest (res) {
        variety 14:
            plant("{}", (30 - 1));
            prune;
        variety 12:
            plant("{}", res);
